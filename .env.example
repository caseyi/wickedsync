# Copy this to .env and fill in your values.
# Then run: docker-compose up -d

# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Your Gumroad session cookies.
# How to get them:
#   1. Log into gumroad.com in Chrome
#   2. Open DevTools (F12) → Application tab → Cookies → https://gumroad.com
#   3. Copy the VALUE of _gumroad_app_session
#   4. Copy the VALUE of _gumroad_guid
#   5. Paste in the format below:
GUMROAD_COOKIES=_gumroad_app_session=PASTE_VALUE_HERE; _gumroad_guid=PASTE_VALUE_HERE
